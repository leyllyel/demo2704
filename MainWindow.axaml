<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:CompileBindings="False"
        x:Class="Demo2704.MainWindow"
        Title="ООО '41 размер'">
    
   <Grid RowDefinitions="Auto,*"> 
    <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,20">
        <Image Source="..\Resources\logo.png" Height="80"/>
        <TextBlock Text="ООО '41 размер'" FontSize="22" HorizontalAlignment="Center" />
        <TextBlock Text="Авторизация" FontSize="22" HorizontalAlignment="Center" />
    </StackPanel>

    <Border Grid.Row="1"
            CornerRadius="10"
            Padding="40"
            Background="#fff2cc"
            VerticalAlignment="Top" 
            HorizontalAlignment="Center"
            Margin="0,20">
        
        <StackPanel Width="350" Spacing="15">
            <StackPanel>
                <TextBlock Text="Логин"/>
                <TextBox Name="LoginBox" Watermark="Введите логин"/>
            </StackPanel>
            
            <StackPanel>
                <TextBlock Text="Пароль"/>
                <TextBox Name="PasswordBox"
                         Watermark="Введите пароль"
                         PasswordChar="*"/>
            </StackPanel>

            <StackPanel Spacing="10" Margin="0,10,0,0">
                <Button Name="AuthButton"
                        Click="AuthButton_Click"
                        Content="Войти"
                        Width="200" Padding="10"
                        Background="#c45911" Foreground="White"
                        HorizontalAlignment="Center" HorizontalContentAlignment="Center" />
                <Button Name="GuestButton"
                        Click="GuestButton_Click"
                        Content="Гостевой вход"
                        Width="200" Padding="10"
                        Background="#c45911" Foreground="White"
                        HorizontalAlignment="Center" HorizontalContentAlignment="Center" />
            </StackPanel>
        </StackPanel> 
    </Border> 
    
</Grid>
</Window>